# ══════════════════════════════════════════════════════════
#  AMILCAR Auto Care — Production Environment
#  Copy to .env.production and fill in real values
# ══════════════════════════════════════════════════════════

# ─── Domain ───
DOMAIN=amilcar.example.com

# ─── Database ───
DB_USER=amilcar_user
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=amilcar_db

# ─── App / JWT ───
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_64
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── CORS (comma-separated) ───
ALLOWED_ORIGINS=https://amilcar.example.com

# ─── Firebase ───
FIREBASE_PROJECT_ID=amilcar-autocare
FIREBASE_SERVICE_ACCOUNT_FILE=firebase/service-account.json

# ─── SSL (your email for Let's Encrypt) ───
CERTBOT_EMAIL=admin@example.com
